APP_NAME=deepresearch-orchestrator
APP_ENV=production
LOG_LEVEL=INFO
POSTGRES_IMAGE=postgres:16.13-bookworm
POSTGRES_DB=deepresearch
POSTGRES_USER=deepresearch
POSTGRES_PASSWORD=deepresearch
POSTGRES_PORT=5432
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.19.0
OPENSEARCH_CLUSTER_NAME=deepresearch-single-node
OPENSEARCH_PASSWORD=ChangeMe123!
OPENSEARCH_PORT=9200
OPENSEARCH_PERF_PORT=9600
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_USERNAME=admin
OPENSEARCH_BASE_URL=https://opensearch:9200
OPENSEARCH_INDEX_NAME=source-chunks-v1
OPENSEARCH_VERIFY_TLS=true
OPENSEARCH_CA_BUNDLE_PATH=/run/opensearch-certs/root-ca.pem
OPENSEARCH_TIMEOUT_SECONDS=10
OPENSEARCH_VALIDATE_CONNECTIVITY_ON_STARTUP=true
SEARXNG_IMAGE=searxng/searxng:2026.4.13-ee66b070a
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_PORT=8080
SEARXNG_TIMEOUT_SECONDS=10
TIKA_IMAGE=apache/tika:3.3.0.0-full
TIKA_PORT=9998
APP_PORT=8000
SEARCH_MAX_RESULTS_PER_QUERY=10
QUERY_EXPANSION_MAX_DOMAINS=3
ACQUISITION_TIMEOUT_SECONDS=10
ACQUISITION_MAX_REDIRECTS=3
ACQUISITION_MAX_RESPONSE_BYTES=1048576
ACQUISITION_MAX_CANDIDATES_PER_REQUEST=5
ACQUISITION_USER_AGENT=deepresearch-orchestrator/0.1
SNAPSHOT_STORAGE_BACKEND=minio
SNAPSHOT_STORAGE_ROOT=/workspace/data/snapshots
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
MINIO_REGION=
SNAPSHOT_STORAGE_BUCKET=snapshots
REPORT_STORAGE_BUCKET=reports
INDEX_BACKEND=opensearch
INDEXING_MAX_CHUNKS_PER_REQUEST=20
RETRIEVAL_MAX_RESULTS_PER_REQUEST=20
CLAIM_DRAFTING_MAX_CANDIDATES_PER_REQUEST=5
CLAIM_VERIFICATION_MAX_CLAIMS_PER_REQUEST=5
METRICS_ENABLED=true
