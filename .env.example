APP_NAME=deepresearch-orchestrator
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_URL=sqlite:///./data/dev.db
SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://127.0.0.1:8080
SEARXNG_TIMEOUT_SECONDS=10
SEARCH_MAX_RESULTS_PER_QUERY=10
QUERY_EXPANSION_MAX_DOMAINS=3
ACQUISITION_TIMEOUT_SECONDS=10
ACQUISITION_MAX_REDIRECTS=3
ACQUISITION_MAX_RESPONSE_BYTES=1048576
ACQUISITION_MAX_CANDIDATES_PER_REQUEST=5
ACQUISITION_TARGET_SUCCESSFUL_SNAPSHOTS=2
ACQUISITION_MIN_ANSWER_SOURCES=3
ACQUISITION_MAX_SUPPLEMENTAL_SOURCES=3
ACQUISITION_USER_AGENT=deepresearch-orchestrator/0.1
SNAPSHOT_STORAGE_BACKEND=filesystem
SNAPSHOT_STORAGE_ROOT=./data/snapshots
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_REGION=
SNAPSHOT_STORAGE_BUCKET=snapshots
REPORT_STORAGE_BUCKET=reports
INDEX_BACKEND=opensearch
OPENSEARCH_BASE_URL=http://127.0.0.1:9200
OPENSEARCH_INDEX_NAME=source-chunks-v1
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_TLS=true
OPENSEARCH_CA_BUNDLE_PATH=
OPENSEARCH_TIMEOUT_SECONDS=10
OPENSEARCH_VALIDATE_CONNECTIVITY_ON_STARTUP=false
INDEXING_MAX_CHUNKS_PER_REQUEST=20
RETRIEVAL_MAX_RESULTS_PER_REQUEST=20
CLAIM_DRAFTING_MAX_CANDIDATES_PER_REQUEST=5
CLAIM_VERIFICATION_MAX_CLAIMS_PER_REQUEST=5
LLM_ENABLED=false
LLM_PROVIDER=noop
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LLM_MAX_OUTPUT_TOKENS=1200
RESEARCH_PLANNER_ENABLED=false
RESEARCH_PLANNER_MAX_SUBQUESTIONS=5
RESEARCH_PLANNER_MAX_SEARCH_QUERIES=8
METRICS_ENABLED=true
