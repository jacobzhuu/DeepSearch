APP_NAME=deepresearch-orchestrator
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_URL=sqlite:///./data/dev.db
SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://127.0.0.1:8080
SEARXNG_TIMEOUT_SECONDS=10
SEARCH_MAX_RESULTS_PER_QUERY=10
QUERY_EXPANSION_MAX_DOMAINS=3
ACQUISITION_TIMEOUT_SECONDS=10
ACQUISITION_MAX_REDIRECTS=3
ACQUISITION_MAX_RESPONSE_BYTES=1048576
ACQUISITION_MAX_CANDIDATES_PER_REQUEST=5
ACQUISITION_TARGET_SUCCESSFUL_SNAPSHOTS=2
ACQUISITION_MIN_ANSWER_SOURCES=3
ACQUISITION_MAX_SUPPLEMENTAL_SOURCES=3
RESEARCH_GAP_MAX_ROUNDS=2
RESEARCH_GAP_MAX_QUERIES_PER_ROUND=4
RESEARCH_LOOP_ENABLED=false
RESEARCH_LOOP_STRATEGIST_ENABLED=false
RESEARCH_LOOP_STRATEGIST_SHADOW_MODE=true
RESEARCH_LOOP_MAX_ROUNDS=3
RESEARCH_LOOP_MAX_TOTAL_QUERIES=16
RESEARCH_LOOP_MAX_QUERIES_PER_ROUND=5
RESEARCH_LOOP_MAX_TOTAL_FETCH_ATTEMPTS=20
RESEARCH_LOOP_MAX_STRATEGY_CALLS=4
RESEARCH_LOOP_MIN_DISTINCT_DOMAINS=3
RESEARCH_LOOP_MIN_AUTHORITATIVE_SOURCES=1
RESEARCH_LOOP_REQUIRED_SLOT_MIN_STATUS=moderate
RESEARCH_LOOP_ALLOW_LOW_COVERAGE_REPORT=true
RESEARCH_ACQUISITION_MAX_MUST_FETCH_PER_ROUND=3
RESEARCH_WORKER_POLL_INTERVAL_SECONDS=2
RESEARCH_WORKER_BATCH_SIZE=1
ACQUISITION_USER_AGENT=deepresearch-orchestrator/0.1
ACQUISITION_TRUST_ENV_PROXY=false
SNAPSHOT_STORAGE_BACKEND=filesystem
SNAPSHOT_STORAGE_ROOT=./data/snapshots
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_REGION=
SNAPSHOT_STORAGE_BUCKET=snapshots
REPORT_STORAGE_BUCKET=reports
INDEX_BACKEND=opensearch
OPENSEARCH_BASE_URL=http://127.0.0.1:9200
OPENSEARCH_INDEX_NAME=source-chunks-v1
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_TLS=true
OPENSEARCH_CA_BUNDLE_PATH=
OPENSEARCH_TIMEOUT_SECONDS=10
OPENSEARCH_VALIDATE_CONNECTIVITY_ON_STARTUP=false
INDEXING_MAX_CHUNKS_PER_REQUEST=20
RETRIEVAL_MAX_RESULTS_PER_REQUEST=20
CLAIM_DRAFTING_MAX_CANDIDATES_PER_REQUEST=5
CLAIM_VERIFICATION_MAX_CLAIMS_PER_REQUEST=5
LLM_ENABLED=true
LLM_PROVIDER=noop
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_TRUST_ENV_PROXY=false
LLM_MAX_OUTPUT_TOKENS=1200
LLM_REPORT_WRITER_ENABLED=true
LLM_REPORT_MAX_OUTPUT_TOKENS=2400
# Optional structured LLM synthesis appendix (defaults off; see docs/runbook.md).
LLM_STRUCTURED_SYNTHESIS_ENABLED=false
LLM_REPORT_STRUCTURE_ENABLED=false
LLM_METHOD_CARD_EXTRACTION_ENABLED=false
LLM_COMPARISON_TABLE_ENABLED=false
LLM_SYNTHESIS_INSIGHTS_ENABLED=false
LLM_STRUCTURED_SYNTHESIS_CONFIDENCE_THRESHOLD=0.55
LLM_STRUCTURED_SYNTHESIS_MAX_INPUT_CHARS=12000
LLM_SOURCE_JUDGE_ENABLED=true
LLM_SOURCE_JUDGE_ACTIVE_RERANK=true
LLM_SOURCE_TRIAGE_ACTIVE=true
LLM_SOURCE_JUDGE_MAX_CANDIDATES=5
LLM_CLAIM_REVIEWER_ENABLED=true
LLM_CLAIM_REVIEWER_MAX_CLAIMS=12
RESEARCH_PLANNER_ENABLED=true
RESEARCH_PLANNER_MAX_SUBQUESTIONS=5
RESEARCH_PLANNER_MAX_SEARCH_QUERIES=8
METRICS_ENABLED=true
